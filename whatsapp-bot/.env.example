# Base URL aplikasi Next.js Root-VCR (tanpa trailing slash).
# Contoh lokal: http://localhost:3000  |  produksi: https://app.domain.com
BASE_URL=http://localhost:3000

# Shared secret untuk endpoint internal /api/bot/* (header x-bot-secret).
# HARUS sama persis dengan BOT_API_SECRET di .env aplikasi Next.js.
BOT_API_SECRET=ganti-dengan-secret-yang-sama-dengan-app
