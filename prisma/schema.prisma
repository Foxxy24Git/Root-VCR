generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  RESELLER
}

enum InvoiceStatus {
  PENDING
  AWAITING_VERIFICATION
  PAID
  OVERDUE
  CANCELLED
}

enum VoucherStatus {
  unused
  active
  inactive
  expired
  deleted
}

enum VoucherSource {
  admin
  reseller
}

enum WalletLogType {
  topup
  deduct
  generate
  refund
  adjustment
}

// ─────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password_hash  String
  name           String    @db.VarChar(100)
  role           Role
  phone          String?   @db.VarChar(20)
  location       String?   @db.VarChar(255)
  avatar_url     String?   @db.VarChar(500)
  is_active      Boolean   @default(true)
  is_frozen      Boolean   @default(false)
  fee_percentage Decimal   @default(0.00) @db.Decimal(5, 2)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  tenant_id      String?

  vouchers          Voucher[]
  wallet            Wallet?
  reseller_profiles ResellerProfile[]
  wallet_logs       WalletLog[]       @relation("AdminWalletLogs")
  tenant            Tenant?           @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Voucher Profiles (packages)
// ─────────────────────────────────────────────────────────────

model Profile {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(100)
  duration_days    Int
  duration_hours   Int      @default(0)
  price            Decimal  @db.Decimal(12, 2)
  speed_limit      String?  @db.VarChar(50)
  mikrotik_profile String   @db.VarChar(100)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  tenant_id        String

  vouchers          Voucher[]
  reseller_profiles ResellerProfile[]
  tenant            Tenant            @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────
// Vouchers
// ─────────────────────────────────────────────────────────────

model Voucher {
  id              String        @id @default(uuid())
  code            String        @unique @db.VarChar(50)
  password        String?       @db.VarChar(60)
  user_id         String?
  profile_id      String?
  status          VoucherStatus @default(unused)
  price_charged   Decimal       @db.Decimal(12, 2)
  generated_at    DateTime      @default(now())
  used_at         DateTime?
  expired_at      DateTime?
  client_ip       String?       @db.VarChar(45)
  client_mac      String?       @db.VarChar(17)
  mikrotik_synced Boolean       @default(false)
  source          VoucherSource @default(reseller)
  created_at      DateTime      @default(now())
  tenant_id       String

  user    User?    @relation(fields: [user_id], references: [id])
  profile Profile? @relation(fields: [profile_id], references: [id])
  tenant  Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("vouchers")
}

// ─────────────────────────────────────────────────────────────
// Wallets
// ─────────────────────────────────────────────────────────────

model Wallet {
  id          String   @id @default(uuid())
  user_id     String   @unique
  balance     Decimal  @default(0.00) @db.Decimal(15, 2)
  total_topup Decimal  @default(0.00) @db.Decimal(15, 2)
  total_spent Decimal  @default(0.00) @db.Decimal(15, 2)
  updated_at  DateTime @updatedAt
  tenant_id   String

  user   User        @relation(fields: [user_id], references: [id])
  logs   WalletLog[]
  tenant Tenant      @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("wallets")
}

// ─────────────────────────────────────────────────────────────
// Wallet Logs
// ─────────────────────────────────────────────────────────────

model WalletLog {
  id             String        @id @default(uuid())
  wallet_id      String
  type           WalletLogType
  amount         Decimal       @db.Decimal(15, 2)
  balance_before Decimal       @db.Decimal(15, 2)
  balance_after  Decimal       @db.Decimal(15, 2)
  description    String?
  reference_id   String?       @db.Uuid
  admin_id       String?
  created_at     DateTime      @default(now())
  tenant_id      String

  wallet Wallet @relation(fields: [wallet_id], references: [id])
  admin  User?  @relation("AdminWalletLogs", fields: [admin_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("wallet_logs")
}

// ─────────────────────────────────────────────────────────────
// Reseller Profiles (many-to-many: user <-> profile)
// ─────────────────────────────────────────────────────────────

model ResellerProfile {
  id         String   @id @default(uuid())
  user_id    String
  profile_id String
  is_enabled Boolean  @default(true)
  created_at DateTime @default(now())
  tenant_id  String

  user    User    @relation(fields: [user_id], references: [id])
  profile Profile @relation(fields: [profile_id], references: [id])
  tenant  Tenant  @relation(fields: [tenant_id], references: [id])

  @@unique([user_id, profile_id])
  @@index([tenant_id])
  @@map("reseller_profiles")
}

// ─────────────────────────────────────────────────────────────
// Settings (key-value store)
// ─────────────────────────────────────────────────────────────

model Setting {
  id         String   @id @default(uuid())
  key        String   @db.VarChar(100)
  value      String?
  type       String   @default("string") @db.VarChar(20)
  updated_at DateTime @updatedAt
  tenant_id  String

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, key])
  @@index([tenant_id])
  @@map("settings")
}

// ─────────────────────────────────────────────────────────────
// PPPoE Users (synced from MikroTik)
// ─────────────────────────────────────────────────────────────

model PppoeUser {
  id         String    @id @default(uuid())
  username   String    @db.VarChar(100)
  profile    String?   @db.VarChar(100)
  status     String    @default("inactive") @db.VarChar(20)
  caller_id  String?   @db.VarChar(50)
  last_seen  DateTime?
  synced_at  DateTime  @default(now())
  tenant_id  String

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("pppoe_users")
}

// ─────────────────────────────────────────────────────────────
// Tenants (multi-tenant root)
// ─────────────────────────────────────────────────────────────

model Tenant {
  id                       String    @id @default(uuid())
  name                     String    @db.VarChar(150)
  slug                     String    @unique @db.VarChar(100)
  owner_name               String    @db.VarChar(150)
  owner_email              String    @db.VarChar(255)
  owner_phone              String    @db.VarChar(30)

  // MikroTik configuration (password encrypted)
  mikrotik_host            String    @db.VarChar(255)
  mikrotik_port            Int       @default(8728)
  mikrotik_username        String    @db.VarChar(100)
  mikrotik_password_enc    String
  mikrotik_use_ssl         Boolean   @default(false)
  mikrotik_last_test_at    DateTime?
  mikrotik_last_test_ok    Boolean?
  mikrotik_last_edited_by  String?
  mikrotik_last_edited_at  DateTime?

  // Subscription & trial
  plan_id                  String?
  is_trial                 Boolean   @default(true)
  trial_end_at             DateTime?
  subscription_start_at    DateTime?
  subscription_end_at      DateTime?
  is_active                Boolean   @default(true)
  suspended_reason         String?

  // Per-tenant overrides
  max_resellers            Int       @default(5)
  max_vouchers_per_month   Int       @default(1000)

  // Branding (optional white-label)
  logo_url                 String?   @db.VarChar(500)
  brand_color              String?   @db.VarChar(20)

  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  created_by               String

  // Relations
  plan              Plan?                 @relation(fields: [plan_id], references: [id])
  users             User[]
  profiles          Profile[]
  vouchers          Voucher[]
  wallets           Wallet[]
  wallet_logs       WalletLog[]
  reseller_profiles ResellerProfile[]
  settings          Setting[]
  pppoe_users       PppoeUser[]
  invoices          SubscriptionInvoice[]
  audit_logs        AuditLog[]

  @@index([slug])
  @@index([is_active])
  @@index([is_trial])
  @@index([trial_end_at])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// Plans (subscription packages)
// ─────────────────────────────────────────────────────────────

model Plan {
  id                     String   @id @default(uuid())
  name                   String   @db.VarChar(100)
  description            String?
  price                  Decimal  @db.Decimal(12, 2)
  duration_days          Int      @default(30)
  is_trial               Boolean  @default(false)

  max_resellers          Int
  max_vouchers_per_month Int
  features               Json?

  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())

  tenants Tenant[]

  @@map("plans")
}

// ─────────────────────────────────────────────────────────────
// Subscription Invoices (manual transfer flow)
// ─────────────────────────────────────────────────────────────

model SubscriptionInvoice {
  id              String        @id @default(uuid())
  tenant_id       String
  invoice_number  String        @unique @db.VarChar(50)
  amount          Decimal       @db.Decimal(12, 2)
  period_start    DateTime
  period_end      DateTime
  status          InvoiceStatus @default(PENDING)

  // Manual transfer
  paid_at         DateTime?
  payment_method  String?       @db.VarChar(100)
  payment_proof   String?       @db.VarChar(500)
  payment_notes   String?
  verified_by     String?
  verified_at     DateTime?
  rejected_reason String?

  notes           String?
  created_at      DateTime      @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([status])
  @@map("subscription_invoices")
}

// ─────────────────────────────────────────────────────────────
// Bank Accounts (transfer destinations shown to customers)
// ─────────────────────────────────────────────────────────────

model BankAccount {
  id             String   @id @default(uuid())
  bank_name      String   @db.VarChar(100)
  account_number String   @db.VarChar(50)
  account_holder String   @db.VarChar(150)
  notes          String?
  is_active      Boolean  @default(true)
  display_order  Int      @default(0)

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([is_active])
  @@index([display_order])
  @@map("bank_accounts")
}

// ─────────────────────────────────────────────────────────────
// Audit Logs
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenant_id  String?
  user_id    String?
  action     String   @db.VarChar(100)
  resource   String?  @db.VarChar(255)
  metadata   Json?
  ip_address String?  @db.VarChar(45)
  user_agent String?  @db.VarChar(500)
  created_at DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([user_id])
  @@index([created_at])
  @@map("audit_logs")
}
