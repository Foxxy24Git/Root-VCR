# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/rootvcr?schema=public"

# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-super-secret-key-min-32-chars"

# ─────────────────────────────────────────────
# MikroTik (encrypted at rest)
# ─────────────────────────────────────────────
MIKROTIK_HOST="id-11.tunnel.web.id"
MIKROTIK_PORT="6904"
MIKROTIK_API_PORT="8728"
MIKROTIK_USER="admin"
MIKROTIK_PASSWORD="encrypted_password_here"

# ─────────────────────────────────────────────
# Backup
# ─────────────────────────────────────────────
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="7"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV="production"
APP_NAME="Root.VCR"

# ─────────────────────────────────────────────
# Multi-Tenant
# ─────────────────────────────────────────────
# Used to encrypt per-tenant MikroTik passwords at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Initial Super Admin password (used only on first seed)
SUPER_ADMIN_PASSWORD="change-me-strong-password"
