# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# Connection string used by Prisma. Schema is multi-tenant (single DB, tenant_id
# column on tenant-scoped tables).
DATABASE_URL="postgresql://user:password@localhost:5432/rootvcr?schema=public"

# Disposable database for integration tests. The multi-tenant test suite only
# runs when this is set, and refuses to run unless DATABASE_URL === TEST_DATABASE_URL
# (so it can never touch dev/prod data). See src/tests/helpers/db.ts.
#   DATABASE_URL=$TEST_DATABASE_URL npm run test:integration
TEST_DATABASE_URL=""

# ─────────────────────────────────────────────
# NextAuth / Auth.js v5
# ─────────────────────────────────────────────
# AUTH_SECRET is the canonical secret in Auth.js v5 (NEXTAUTH_SECRET kept as an
# alias for compatibility). Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="same-as-AUTH_SECRET"
# Public URL of the app. In production this MUST be the https:// URL behind your
# reverse proxy — it drives secure-cookie hosts and the same-origin CSRF guard.
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Encryption (per-tenant MikroTik passwords)
# ─────────────────────────────────────────────
# AES-256-GCM key used to encrypt each tenant's MikroTik password at rest.
# MUST decode to exactly 32 bytes. Generate with: openssl rand -hex 32
# WARNING: changing this makes existing encrypted passwords undecryptable.
APP_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ─────────────────────────────────────────────
# Cron jobs (server-side scheduler hits these endpoints)
# ─────────────────────────────────────────────
# Shared bearer token guarding /api/cron/* endpoints. The system crontab calls
# them as: curl -H "Authorization: Bearer $CRON_SECRET" https://host/api/cron/...
# Generate with: openssl rand -hex 24
CRON_SECRET="generate-with-openssl-rand-hex-24"

# ─────────────────────────────────────────────
# Bootstrap (first seed only)
# ─────────────────────────────────────────────
# Initial Super Admin password, consumed by `npm run db:seed`. Change after first
# login. Super admin email defaults to superadmin@root.vcr (see prisma/seed.ts).
SUPER_ADMIN_PASSWORD="change-me-strong-password"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV="production"
APP_NAME="Root.VCR"

# ─────────────────────────────────────────────
# Backup (used by scripts/backup.sh)
# ─────────────────────────────────────────────
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="7"

# ─────────────────────────────────────────────
# Legacy / deprecated
# ─────────────────────────────────────────────
# NOTE: MikroTik connection details are now stored PER TENANT in the database
# (encrypted), configured via the Super Admin / Tenant Admin UI — NOT via env.
# These single-tenant vars are retained only for older one-shot scripts and are
# ignored by the multi-tenant app. Leave unset for new deployments.
# MIKROTIK_HOST=""
# MIKROTIK_PORT=""
# MIKROTIK_API_PORT=""
# MIKROTIK_USER=""
# MIKROTIK_PASSWORD=""
